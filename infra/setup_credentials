#!/usr/bin/env sh
set -euo pipefail

# This script creates the terraform.tfvars file.

script_dir=$(cd "$(dirname "$0")" && pwd)
if [ "$script_dir" != "$(pwd)" ]; then
	echo "error: must be run from $script_dir" >&2
	exit 1
fi

VAULT="bee-ci"

true >terraform.tfvars # Clear file

_export() {
	name="${1:-}"
	value="${2:-}"

	echo "$name"
	echo "$name = \"$value\"" >>terraform.tfvars
}

_export github_app_id "$(op read "op://$VAULT/GitHub App/app ID")"
_export github_app_webhook_secret "$(op read "op://$VAULT/GitHub App/webhook secret")"
_export github_app_private_key_base64 "$(op read "op://$VAULT/GitHub App/private key/content base64")"
_export github_app_client_id "$(op read "op://$VAULT/GitHub App/client ID")"
_export github_app_client_secret "$(op read "op://$VAULT/GitHub App/client secret")"

_export influxdb_password "$(op read "op://$VAULT/InfluxDB/password")"
_export influxdb_token "$(op read "op://$VAULT/InfluxDB/token")"

_export do_token "$(op read "op://$VAULT/DigitalOcean/API token")"
